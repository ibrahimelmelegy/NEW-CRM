# Frontend Environment Variables
# Copy this file to .env and fill in the values

# API Configuration
# The base URL for API calls to the backend
API_BASE_URL=http://localhost:5000/api/

# The base URL for the frontend application
BASE_URL=http://localhost:3060/

# The base URL for uploaded assets (images, documents, etc.)
BUCKET_URL=http://localhost:5000/assets/

# Application Environment
# Options: development, production, staging
NODE_ENV=development

# Feature Flags (optional)
# Enable debug mode for additional logging
ENABLE_DEBUG_MODE=true
