{
  "dependencies": {
    "@tiptap/extension-color": "^3.18.0",
    "@tiptap/extension-highlight": "^3.18.0",
    "@tiptap/extension-image": "^3.18.0",
    "@tiptap/extension-link": "^3.18.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/extension-subscript": "^3.18.0",
    "@tiptap/extension-superscript": "^3.18.0",
    "@tiptap/extension-table": "^3.18.0",
    "@tiptap/extension-table-cell": "^3.18.0",
    "@tiptap/extension-table-header": "^3.18.0",
    "@tiptap/extension-table-row": "^3.18.0",
    "@tiptap/extension-task-item": "^3.18.0",
    "@tiptap/extension-task-list": "^3.18.0",
    "@tiptap/extension-text-align": "^3.18.0",
    "@tiptap/extension-text-style": "^3.18.0",
    "@tiptap/extension-underline": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@tiptap/vue-3": "^3.18.0",
    "nuxt": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.2.0",
    "concurrently": "^9.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "sass-embedded": "^1.97.3"
  },
  "scripts": {
    "install:all": "npm install && cd leadify-backend-main && npm install && cd ../leadify-frontend-main && npm install --legacy-peer-deps",
    "dev:backend": "cd leadify-backend-main && npm run dev",
    "dev:frontend": "cd leadify-frontend-main && npm run dev",
    "dev:all": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build:backend": "cd leadify-backend-main && npm run build",
    "build:frontend": "cd leadify-frontend-main && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "test:backend": "cd leadify-backend-main && npm test",
    "test:frontend": "cd leadify-frontend-main && npm run test",
    "test:all": "npm run test:backend && npm run test:frontend",
    "lint:backend": "cd leadify-backend-main && npm run lint",
    "lint:frontend": "cd leadify-frontend-main && npm run lint",
    "lint:all": "npm run lint:backend && npm run lint:frontend",
    "validate:env": "node scripts/validate-env.js",
    "setup": "node scripts/setup.js",
    "seed": "cd leadify-backend-main && npm run seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{json,md,yml}": [
      "npx prettier --write"
    ]
  }
}
