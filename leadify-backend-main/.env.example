# Application Port
PORT=5000
NODE_ENV=development

# Database configuration
DB_HOST=db                   # Docker Compose service name for PostgreSQL
DB_PORT=5432                 # Default PostgreSQL port
DB_USER=leadify              # PostgreSQL username
DB_PASSWORD=CHANGE_ME        # PostgreSQL password (MUST change in production)
DB_NAME=leadify              # Database name

# Docker / PostgreSQL (used by docker-compose)
POSTGRES_USER=leadify
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=leadify

# JWT Secret Key for authentication (REQUIRED - server won't start without it)
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRATION_TIME=7d

# Admin seed credentials (used by npm run seed)
ADMIN_EMAIL=admin@leadify.com
ADMIN_PASSWORD=Leadify@Admin2026!

# Email Configuration for Nodemailer (using Outlook as an example)
EMAIL_USER=your_email@example.com     # Your email address
EMAIL_PASS=your_email_password        # Your email password (or app-specific password if 2FA is enabled)

ALLOW_SUPER_ADMIN_CREATION=false

BASE_URL=http://localhost:5000/
SESSION_EXPIRATION_TIME=7

SENDGRID_API_KEY=your_sendgrid_api_key  # SendGrid API key for sending emails (if using SendGrid)

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS=http://localhost:3060

# Encryption key for API keys at rest (64-character hex string = 32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Login brute force protection
LOGIN_LOCK_TIME_MS=900000
LOGIN_MAX_ATTEMPTS=5
