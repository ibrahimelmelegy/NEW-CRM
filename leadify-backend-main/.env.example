# Server
NODE_ENV=development
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=leadify_dev
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSL=false

# Docker / PostgreSQL (used by docker-compose)
POSTGRES_USER=leadify
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=leadify

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRE=7d
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRATION_TIME=7d
SESSION_EXPIRATION_TIME=7

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Admin Seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Sentry (optional - error tracking)
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Base URL
BASE_URL=http://localhost:5000/

# SendGrid (optional)
SENDGRID_API_KEY=your_sendgrid_api_key

# Encryption key for API keys at rest (64-character hex string = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Login brute force protection
LOGIN_LOCK_TIME_MS=900000
LOGIN_MAX_ATTEMPTS=5

ALLOW_SUPER_ADMIN_CREATION=false

# HTTPS enforcement (production only)
FORCE_HTTPS=false

# 2FA/MFA (TOTP) - Enabled per-user via /api/auth/2fa/setup
# No env config needed - uses otplib for TOTP generation
# Compatible with Google Authenticator, Authy, Microsoft Authenticator

# ERPNext Integration (optional - for syncing finance data with ERPNext)
ERPNEXT_BASE_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_COMPANY=
ERPNEXT_CURRENCY=SAR
ERPNEXT_ENABLED=false

# Database Backup (optional)
BACKUP_ENABLED=true
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Storage Provider (optional - for cloud file storage)
STORAGE_PROVIDER=local
DO_SPACES_CDN_URL=
